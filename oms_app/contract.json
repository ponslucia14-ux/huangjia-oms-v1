{
  "schema_version": "oms.contract.v1.0",
  "contract_name": "OMS Contract Layer v1.0",
  "contract_mode": "Data Contract + Action Contract + Semantic Contract",
  "system_goal": "OMS = Contract-driven System",
  "source": "OMS_TRUTH_SOURCE",
  "single_truth_root": "D:\\OMS_V1\\OMS_TRUTH_SOURCE",
  "runtime_root": "D:\\OMS_V1\\live_runtime",
  "rules": {
    "api_must_return_contract_envelope": true,
    "ui_must_read_payload_not_raw_response": true,
    "ui_without_behavior_is_forbidden": true,
    "semantic_drift_is_forbidden": true,
    "excel_as_runtime_source_allowed": false,
    "ui_calculated_truth_allowed": false,
    "multiple_data_sources_allowed": false
  },
  "data_contract": {
    "response_envelope": {
      "required_fields": [
        "entity",
        "id",
        "status",
        "payload",
        "timestamp",
        "source"
      ],
      "optional_fields": [
        "contract_version",
        "error"
      ],
      "entity_enum": [
        "room",
        "finance",
        "sales",
        "task"
      ],
      "status_enum": [
        "ready",
        "partial",
        "pending",
        "blocked",
        "not_found",
        "invalid_json",
        "identity_binding_required",
        "failed"
      ],
      "source_required_value": "OMS_TRUTH_SOURCE",
      "timestamp_format": "ISO-8601",
      "payload_rule": "Endpoint-specific data must be inside payload. UI must not treat any top-level field except the envelope as business data."
    },
    "api_field_spec_table": [
      {
        "api": "/api/oms/home",
        "methods": [
          "GET",
          "POST"
        ],
        "entity": "task",
        "id": "oms.home",
        "required_request_fields": [
          "user_id"
        ],
        "required_response_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "required_payload_fields": [
          "schema_version",
          "entry",
          "current_user",
          "home_title",
          "sections",
          "business_dashboard",
          "runtime_source"
        ],
        "ui_required_fields": [
          "payload.current_user.name",
          "payload.current_user.role",
          "payload.home_title",
          "payload.sections.my_todos",
          "payload.sections.my_tasks",
          "payload.sections.my_approvals",
          "payload.sections.role_home",
          "payload.business_dashboard"
        ],
        "optional_payload_fields": [
          "decision_assist",
          "sync_status",
          "bottom_tabs",
          "core_fusion",
          "master_control",
          "empty_state"
        ],
        "failure_status": [
          "identity_binding_required",
          "blocked"
        ]
      },
      {
        "api": "/api/feishu/identity",
        "methods": [
          "POST"
        ],
        "entity": "task",
        "id": "feishu.identity.exchange",
        "required_request_fields": [
          "code"
        ],
        "required_response_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "required_payload_fields": [
          "user_id or open_id or union_id"
        ],
        "ui_required_fields": [
          "payload.user_id or payload.open_id or payload.union_id"
        ],
        "optional_payload_fields": [
          "workspace_key",
          "source",
          "tenant_key"
        ],
        "failure_status": [
          "blocked",
          "failed"
        ]
      },
      {
        "api": "/api/oms/history",
        "methods": [
          "GET",
          "POST"
        ],
        "entity": "task",
        "id": "oms.history",
        "required_request_fields": [],
        "required_response_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "required_payload_fields": [
          "schema_version",
          "timeline",
          "traceability",
          "runtime_source"
        ],
        "ui_required_fields": [
          "payload.timeline",
          "payload.traceability"
        ],
        "optional_payload_fields": [
          "filters",
          "multidimensional_history",
          "timeline_total_count",
          "timeline_visible_count"
        ],
        "failure_status": [
          "blocked",
          "failed"
        ]
      }
    ],
    "business_entities": {
      "room": {
        "required_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "payload_required": [
          "room_id",
          "room_type",
          "room_status",
          "guest_id",
          "checkin_date",
          "checkout_date"
        ]
      },
      "finance": {
        "required_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "payload_required": [
          "tx_id",
          "type",
          "amount",
          "related_guest",
          "related_room",
          "timestamp"
        ]
      },
      "sales": {
        "required_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "payload_required": [
          "contract_id",
          "guest_id",
          "stage",
          "amount",
          "salesperson_id"
        ]
      },
      "task": {
        "required_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "payload_required": [
          "task_id",
          "assigned_user_id",
          "workspace_key",
          "next_action",
          "trace_chain"
        ]
      }
    }
  },
  "action_contract": {
    "principle": "Every visible UI action must map to exactly one route, one state update, and one API/data refresh rule.",
    "required_state_fields": [
      "current_route",
      "selected_task",
      "current_room",
      "active_workflow",
      "selected_target",
      "selected_action",
      "api_status"
    ],
    "ui_behavior_mapping_table": [
      {
        "ui_trigger": "[data-work-action='open-action']",
        "route": "action",
        "state_update": "selected_task",
        "api": "/api/oms/home",
        "result": "Render selected task detail and refresh current workspace payload"
      },
      {
        "ui_trigger": "[data-work-action='open-status']",
        "route": "status",
        "state_update": "active_workflow",
        "api": "/api/oms/home",
        "result": "Render current business status and refresh current workspace payload"
      },
      {
        "ui_trigger": "[data-work-action='open-room']",
        "route": "room",
        "state_update": "current_room",
        "api": "/api/oms/home",
        "result": "Render room detail and current room tasks"
      },
      {
        "ui_trigger": "[data-work-action='trace-finance']",
        "route": "finance",
        "state_update": "active_workflow",
        "api": "/api/oms/home",
        "result": "Render finance trace and current finance events"
      },
      {
        "ui_trigger": "[data-work-action='open-sales']",
        "route": "sales",
        "state_update": "active_workflow",
        "api": "/api/oms/home",
        "result": "Render sales follow-up and customer status"
      },
      {
        "ui_trigger": "[data-work-action='execute-task']",
        "route": "action",
        "state_update": "selected_task",
        "api": "/api/oms/home",
        "result": "Render task execution state and refresh after action"
      },
      {
        "ui_trigger": "[data-work-action contains '风险']",
        "route": "risk",
        "state_update": "active_workflow",
        "api": "/api/oms/home",
        "result": "Render risk drill-down and current blocker state"
      },
      {
        "ui_trigger": "[data-work-action contains '来源' or '追踪']",
        "route": "data",
        "state_update": "active_workflow",
        "api": "/api/oms/history",
        "result": "Render trace chain for selected item"
      },
      {
        "ui_trigger": "[data-nav-route='home']",
        "route": "home",
        "state_update": "current_route",
        "api": "/api/oms/home",
        "result": "Render HOME as Action + Status + Risk"
      },
      {
        "ui_trigger": "[data-nav-route='action']",
        "route": "action",
        "state_update": "current_route",
        "api": "/api/oms/home",
        "result": "Render today's work"
      },
      {
        "ui_trigger": "[data-nav-route='risk']",
        "route": "risk",
        "state_update": "current_route",
        "api": "/api/oms/home",
        "result": "Render risks and exceptions"
      },
      {
        "ui_trigger": "[data-nav-route='data']",
        "route": "data",
        "state_update": "current_route",
        "api": "/api/oms/history",
        "result": "Render traceability query view"
      }
    ],
    "forbidden": [
      "Visible button without data-work-action or data-nav-route",
      "Click without route change",
      "Click without state update",
      "Click without API refresh or explicit local state result",
      "UI action that writes business meaning outside this contract"
    ]
  },
  "semantic_contract": {
    "principle": "Business words must have one backend definition and one frontend display meaning.",
    "terms": {
      "在住": {
        "entity": "room",
        "definition": "A guest/mother currently checked in and occupying or assigned to a room.",
        "source": "OMS_TRUTH_SOURCE/room.json",
        "ui_meaning": "当前正在服务的入住对象",
        "forbidden_meaning": "Do not count leads, reservations, or historical checkout rows as current resident."
      },
      "任务": {
        "entity": "task",
        "definition": "A work item generated from business_event_flow and assigned to a real user/workspace for execution.",
        "source": "OMS_TRUTH_SOURCE/events.jsonl and workflow_distribution",
        "ui_meaning": "今天要处理的具体动作",
        "forbidden_meaning": "Do not show raw task totals as user-facing meaning without action text."
      },
      "财务": {
        "entity": "finance",
        "definition": "Income, expense, receivable, payable, reimbursement, or settlement event with amount and trace chain.",
        "source": "OMS_TRUTH_SOURCE/finance.json",
        "ui_meaning": "收款、待收、支出、报销、对账与利润动作",
        "forbidden_meaning": "Do not infer finance truth from UI totals."
      },
      "排房": {
        "entity": "room",
        "definition": "Room allocation result generated from room entity, customer priority, check-in time, care needs, and resource load.",
        "source": "OMS_TRUTH_SOURCE/room.json and RoomAllocationEngine",
        "ui_meaning": "房间分配、冲突、调整建议与下一步执行",
        "forbidden_meaning": "Do not let UI calculate room allocation independently."
      },
      "报销": {
        "entity": "finance",
        "definition": "A finance payable/reimbursement event that must preserve source_file, row_id, business_event_id, workflow_task_id, and hr_execution_id when available.",
        "source": "OMS_TRUTH_SOURCE/finance.json",
        "ui_meaning": "需要确认、支付或追踪来源的报销事项",
        "forbidden_meaning": "Do not merge reimbursement into generic expense without traceability."
      }
    }
  }
}
