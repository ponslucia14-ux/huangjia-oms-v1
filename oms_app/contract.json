          }
        ]
      },
      {
        "key": "business",
        "label": "业务",
        "route": "status",
        "target": "业务流",
        "tone": "green",
        "children": [
          {
            "key": "room",
            "label": "房态",
            "route": "room",
            "target": "房态流",
            "tone": "blue"
          },
          {
            "key": "finance",
            "label": "财务",
            "route": "finance",
