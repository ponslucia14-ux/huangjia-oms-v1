  "e2e_ui_chain_contract": {
    "chain_name": "data -> behavior -> display",
    "required_steps": [
      "contract_loaded",
      "api_payload_mapped",
      "component_tree_built",
      "dom_rendered",
      "interaction_bound",
      "api_refresh_bridge_bound"
    ],
    "required_dom_targets": [
      "#todayWorkData",
      "#scoreboardCards",
      "#priorityCards",
      "#businessMenu",
      "#personalWorkspacePanels",
      "#sourceEvidenceRecords"
    ],
    "required_interaction_selectors": [
      "[data-work-action]",
      "[data-nav-route]"
    ],
    "display_validation": {
      "required_sections_visible": [
        "Action",
        "Status",
        "Risk"
      ],
      "empty_dom_blocks_chain": true,
      "click_without_state_update_blocks_chain": true,
      "api_refresh_without_render_update_blocks_chain": true
    },
    "runtime_debug_state": "window.OMS_UI_CHAIN_STATE",
    "dom_debug_flag": "data-oms-ui-chain"
  },
  "final_render_contract": {
    "sink_name": "FINAL_RENDER_SINK",
    "single_entry_function": "render(source)",
    "render_flow": "data -> diff -> commit -> render -> commit DOM",
    "snapshot_versioning_required": true,
    "dom_diff_lock_required": true,
    "render_queue_required": true,
    "queue_policy": "latest_snapshot_wins",
    "partial_render_allowed": false,
    "direct_component_dom_write_allowed": false,
    "async_race_render_allowed": false,
    "state_dom_mismatch_allowed": false,
    "required_snapshot_fields": [
      "version",
      "source",
      "mode",
      "componentTree",
      "dom",
      "hash"
    ],
    "required_dom_commit_targets": [
      "#homeTitle",
      "#homeSubtitle",
      "#lockedUserName",
      "#lockedUserRole",
      "#workspaceStatus",
      "#scoreboardCards",
      "#priorityCards",
      "#sideBusinessMenu",
      "#businessMenu",
      "#personalWorkspacePanels",
      "#sourceEvidenceRecords",
      "#todayWorkData"
    ],
    "runtime_debug_state": "window.OMS_FINAL_RENDER_STATE",
    "dom_debug_flag": "data-oms-final-render"
  },
  "semantic_contract": {
    "principle": "Business words must have one backend definition and one frontend display meaning.",
    "terms": {
      "在住": {
        "entity": "room",
        "definition": "A guest/mother currently checked in and occupying or assigned to a room.",
        "source": "OMS_TRUTH_SOURCE/room.json",
        "ui_meaning": "当前正在服务的入住对象",
        "forbidden_meaning": "Do not count leads, reservations, or historical checkout rows as current resident."
      },
      "任务": {
        "entity": "task",
        "definition": "A work item generated from business_event_flow and assigned to a real user/workspace for execution.",
        "source": "OMS_TRUTH_SOURCE/events.jsonl and workflow_distribution",
        "ui_meaning": "今天要处理的具体动作",
        "forbidden_meaning": "Do not show raw task totals as user-facing meaning without action text."
      },
      "财务": {
        "entity": "finance",
        "definition": "Income, expense, receivable, payable, reimbursement, or settlement event with amount and trace chain.",
        "source": "OMS_TRUTH_SOURCE/finance.json",
        "ui_meaning": "收款、待收、支出、报销、对账与利润动作",
        "forbidden_meaning": "Do not infer finance truth from UI totals."
      },
      "排房": {
        "entity": "room",
