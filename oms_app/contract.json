          }
        ]
      },
      {
        "key": "risk",
        "label": "风险",
        "route": "risk",
        "target": "风险与异常",
        "tone": "purple",
        "children": [
          {
            "key": "delay",
            "label": "延迟事项",
            "route": "risk",
            "target": "延迟事项",
            "tone": "orange"
          },
          {
            "key": "finance_risk",
