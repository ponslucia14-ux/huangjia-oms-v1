{
  "schema_version": "oms.contract.v1.0",
  "contract_name": "OMS Contract Layer v1.0",
  "contract_mode": "Data Contract + Action Contract + Semantic Contract",
  "system_goal": "OMS = Contract-driven System",
  "source": "OMS_TRUTH_SOURCE",
  "single_truth_root": "D:\\OMS_V1\\OMS_TRUTH_SOURCE",
  "runtime_root": "D:\\OMS_V1\\live_runtime",
  "rules": {
    "api_must_return_contract_envelope": true,
    "ui_must_read_payload_not_raw_response": true,
    "ui_without_behavior_is_forbidden": true,
    "semantic_drift_is_forbidden": true,
    "excel_as_runtime_source_allowed": false,
    "ui_calculated_truth_allowed": false,
    "multiple_data_sources_allowed": false
  },
  "data_contract": {
    "response_envelope": {
      "required_fields": [
        "entity",
        "id",
        "status",
        "payload",
        "timestamp",
        "source"
      ],
      "optional_fields": [
        "contract_version",
        "error"
      ],
      "entity_enum": [
        "room",
        "finance",
        "sales",
        "task"
      ],
      "status_enum": [
        "ready",
        "partial",
        "pending",
        "blocked",
        "not_found",
        "invalid_json",
        "identity_binding_required",
        "failed"
      ],
      "source_required_value": "OMS_TRUTH_SOURCE",
      "timestamp_format": "ISO-8601",
      "payload_rule": "Endpoint-specific data must be inside payload. UI must not treat any top-level field except the envelope as business data."
    },
    "api_field_spec_table": [
      {
        "api": "/api/oms/home",
        "methods": [
          "GET",
          "POST"
        ],
        "entity": "task",
        "id": "oms.home",
        "required_request_fields": [
          "user_id"
        ],
        "required_response_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "required_payload_fields": [
          "schema_version",
          "entry",
          "current_user",
          "home_title",
          "sections",
          "business_dashboard",
          "runtime_source"
        ],
        "ui_required_fields": [
          "payload.current_user.name",
          "payload.current_user.role",
          "payload.home_title",
          "payload.sections.my_todos",
          "payload.sections.my_tasks",
          "payload.sections.my_approvals",
          "payload.sections.role_home",
          "payload.business_dashboard",
          "payload.business_dashboard.lifecycle"
        ],
        "optional_payload_fields": [
          "decision_assist",
          "sync_status",
          "bottom_tabs",
          "core_fusion",
          "master_control",
          "empty_state"
        ],
        "failure_status": [
          "identity_binding_required",
          "blocked"
        ]
      },
      {
        "api": "/api/feishu/identity",
        "methods": [
          "POST"
        ],
        "entity": "task",
        "id": "feishu.identity.exchange",
        "required_request_fields": [
          "code"
        ],
        "required_response_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "required_payload_fields": [
          "user_id or open_id or union_id"
        ],
        "ui_required_fields": [
          "payload.user_id or payload.open_id or payload.union_id"
        ],
        "optional_payload_fields": [
          "workspace_key",
          "source",
          "tenant_key"
        ],
        "failure_status": [
          "blocked",
          "failed"
        ]
      },
      {
        "api": "/api/oms/local-owner-access",
        "methods": [
          "POST"
        ],
        "entity": "task",
        "id": "oms.local_owner_access",
        "required_request_fields": [
          "reason"
        ],
        "required_response_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "required_payload_fields": [
          "user_id",
          "workspace_key",
          "source",
          "audit_id"
        ],
        "ui_required_fields": [
          "payload.user_id",
          "payload.workspace_key",
          "payload.audit_id"
        ],
        "optional_payload_fields": [
          "policy"
        ],
        "failure_status": [
          "identity_binding_required",
          "blocked",
          "failed"
        ]
      },
      {
        "api": "/api/oms/execute",
        "methods": [
          "POST"
        ],
        "entity": "task",
        "id": "oms.execute",
        "required_request_fields": [
          "user_id",
          "route",
          "action",
          "target"
        ],
        "required_response_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "required_payload_fields": [
          "schema_version",
          "status",
          "closure_status",
          "action_event",
          "business_command",
          "execution_result",
          "state_update",
          "decision_chain",
          "retrigger_closure",
          "business_state_writeback",
          "lifecycle_closure",
          "trace_chain",
          "ui_reflect"
        ],
        "ui_required_fields": [
          "payload.closure_status",
          "payload.business_state_writeback.status",
          "payload.business_state_writeback.truth_source_updated",
          "payload.decision_chain.decision_summary",
          "payload.retrigger_closure.status",
          "payload.lifecycle_closure.current_stage",
          "payload.lifecycle_closure.closure_detection.status",
          "payload.ui_reflect.message",
          "payload.trace_chain.execution_result_id",
          "payload.trace_chain.state_update_id"
        ],
        "optional_payload_fields": [
          "workflow_task",
          "hr_execution",
          "runtime_paths",
          "blocking_reason"
        ],
        "failure_status": [
          "blocked",
          "failed"
        ]
      },
      {
        "api": "/api/oms/history",
        "methods": [
          "GET",
          "POST"
        ],
        "entity": "task",
        "id": "oms.history",
        "required_request_fields": [],
        "required_response_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "required_payload_fields": [
          "schema_version",
          "timeline",
          "traceability",
          "runtime_source"
        ],
        "ui_required_fields": [
          "payload.timeline",
          "payload.traceability"
        ],
        "optional_payload_fields": [
          "filters",
          "multidimensional_history",
          "timeline_total_count",
          "timeline_visible_count"
        ],
        "failure_status": [
          "blocked",
          "failed"
        ]
      }
    ],
    "business_entities": {
      "room": {
        "required_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "payload_required": [
          "room_id",
          "room_type",
          "room_status",
          "guest_id",
          "checkin_date",
          "checkout_date"
        ]
      },
      "finance": {
        "required_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "payload_required": [
          "tx_id",
          "type",
          "amount",
          "related_guest",
          "related_room",
          "timestamp"
        ]
      },
      "sales": {
        "required_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "payload_required": [
          "contract_id",
          "guest_id",
          "stage",
          "amount",
          "salesperson_id"
        ]
      },
      "task": {
        "required_fields": [
          "entity",
          "id",
          "status",
          "payload",
          "timestamp",
          "source"
        ],
        "payload_required": [
          "task_id",
          "assigned_user_id",
          "workspace_key",
          "next_action",
          "trace_chain"
        ]
      }
    }
  },
  "action_contract": {
    "principle": "Every visible UI action must map to exactly one route, one state update, and one API/data refresh rule.",
    "required_state_fields": [
      "current_route",
      "selected_task",
      "current_room",
      "active_workflow",
      "selected_target",
      "selected_action",
      "api_status",
      "execution_status",
      "closure_status",
      "execution_trace_id",
      "state_update_id",
      "decision_summary",
      "retrigger_status",
      "lifecycle_stage",
      "lifecycle_status"
    ],
    "ui_behavior_mapping_table": [
      {
        "ui_trigger": "[data-work-action='open-action']",
        "route": "action",
        "state_update": "selected_task",
        "api": "/api/oms/execute",
        "result": "Create action event, execute task command, write state update, then refresh workspace payload"
      },
      {
        "ui_trigger": "[data-work-action='open-status']",
        "route": "status",
        "state_update": "active_workflow",
        "api": "/api/oms/execute",
        "result": "Create status action event, execute business command, write state update, then refresh workspace payload"
      },
      {
        "ui_trigger": "[data-work-action='open-room']",
        "route": "room",
        "state_update": "current_room",
        "api": "/api/oms/execute",
        "result": "Create room action event, execute room command, write state update, then render current room tasks"
      },
      {
        "ui_trigger": "[data-work-action='trace-finance']",
        "route": "finance",
        "state_update": "active_workflow",
        "api": "/api/oms/execute",
        "result": "Create finance action event, execute finance command, write state update, then render finance trace"
      },
      {
        "ui_trigger": "[data-work-action='open-sales']",
        "route": "sales",
        "state_update": "active_workflow",
        "api": "/api/oms/execute",
        "result": "Create sales action event, execute sales command, write state update, then render customer status"
      },
      {
        "ui_trigger": "[data-work-action='execute-task']",
        "route": "action",
        "state_update": "selected_task",
        "api": "/api/oms/execute",
        "result": "Create task action event, execute workflow command, write state update, then refresh after action"
      },
      {
        "ui_trigger": "[data-work-action contains '风险']",
        "route": "risk",
        "state_update": "active_workflow",
        "api": "/api/oms/execute",
        "result": "Create risk action event, execute risk command, write state update, then render current blocker state"
      },
      {
        "ui_trigger": "[data-work-action contains '来源' or '追踪']",
        "route": "data",
        "state_update": "active_workflow",
        "api": "/api/oms/execute",
        "result": "Create trace action event, execute trace command, write state update, then render trace chain for selected item"
      },
      {
        "ui_trigger": "[data-work-action contains '重新']",
        "route": "current_route",
        "state_update": "active_workflow",
        "api": "/api/oms/execute",
        "result": "Create re-trigger action event, re-run the relevant decision engine, write re-trigger result, then refresh workspace payload"
      },
      {
        "ui_trigger": "[data-nav-route='home']",
        "route": "home",
        "state_update": "current_route",
        "api": "/api/oms/home",
        "result": "Render HOME as Action + Status + Risk"
      },
      {
        "ui_trigger": "[data-nav-route='action']",
        "route": "action",
        "state_update": "current_route",
        "api": "/api/oms/home",
        "result": "Render today's work"
      },
      {
        "ui_trigger": "[data-nav-route='risk']",
        "route": "risk",
        "state_update": "current_route",
        "api": "/api/oms/home",
        "result": "Render risks and exceptions"
      },
      {
        "ui_trigger": "[data-nav-route='data']",
        "route": "data",
        "state_update": "current_route",
        "api": "/api/oms/history",
        "result": "Render traceability query view"
      },
      {
        "ui_trigger": "[data-nav-route='sales']",
        "route": "sales",
        "state_update": "active_workflow",
        "api": "/api/oms/home",
        "result": "Render sales center from sales_schema and sales_contract_data"
      },
      {
        "ui_trigger": "[data-nav-route='finance']",
        "route": "finance",
        "state_update": "active_workflow",
        "api": "/api/oms/home",
        "result": "Render finance center from finance_schema, finance_data, and financial_events"
      },
      {
        "ui_trigger": "[data-nav-route='operations']",
        "route": "operations",
        "state_update": "active_workflow",
        "api": "/api/oms/home",
        "result": "Render operations center from resident, room, service, and hr execution data"
      }
    ],
    "forbidden": [
      "Visible button without data-work-action or data-nav-route",
      "Click without route change",
      "Click without state update",
      "Click without API refresh or explicit local state result",
      "UI action that writes business meaning outside this contract"
    ]
  },
