            "route": "status",
            "target": "现在发生什么",
            "tone": "green"
          },
          {
            "key": "exceptions",
            "label": "风险异常",
            "route": "risk",
            "target": "哪里有问题",
            "tone": "purple"
          }
        ]
      },
      {
        "key": "work",
        "label": "工作",
        "route": "action",
        "target": "我的工作",
        "tone": "orange",
        "children": [
          {
            "key": "my_todos",
            "label": "我的待办",
            "route": "action",
            "target": "我的待办",
            "tone": "orange"
          },
          {
            "key": "my_tasks",
            "label": "我的任务",
            "route": "action",
            "target": "我的任务",
            "tone": "green"
          },
          {
            "key": "my_approvals",
            "label": "我的审批",
            "route": "action",
            "target": "我的审批",
