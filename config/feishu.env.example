# Feishu Open Platform credentials for Huangjia OMS.
# Copy this file to config/secrets/feishu.env and fill values locally.
# Do not paste App Secret into chat, docs, or committed files.

FEISHU_APP_TYPE=internal
FEISHU_APP_NAME=凰家OMS系统
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional webhook/event settings.
FEISHU_EVENT_WEBHOOK_URL=
FEISHU_EVENT_ENCRYPT_KEY=
FEISHU_EVENT_VERIFICATION_TOKEN=

# MVP write-test targets. Fill only when 石磊 authorizes a real test target.
FEISHU_TEST_CHAT_ID=
FEISHU_TEST_OPEN_ID=
FEISHU_TEST_APPROVAL_CODE=
FEISHU_TEST_APPLICANT_USER_ID=
FEISHU_TEST_APPROVER_USER_ID=

# OMS real-world mapping rule:
# Do not fill role IDs manually. user_id/open_id/chat_id/approval_code must come from Feishu real APIs
# after users, groups, and approval flows are created in the Feishu tenant.

# OMS audit and rollback policy.
OMS_FEISHU_WRITE_MODE=pending_until_verified
OMS_FEISHU_AUDIT_REQUIRED=true
OMS_FEISHU_ROLLBACK_REQUIRED=true
